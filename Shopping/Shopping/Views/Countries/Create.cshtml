@model Shopping.Data.Entities.Country

@{
    ViewData["Title"] = "Create";
}

@*<h1>Crear</h1>*@

<div class="container bg-secondary text-white text-center rounded-3 w-50 p-3" >
<h1>Crear Nuevo</h1>
</div>

<h4>País</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <partial name="_Country" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="States" />

            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-success">Regresar</a>
            </div>
        </form>
    </div>
</div>

<div>
    
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
